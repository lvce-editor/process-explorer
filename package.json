{
  "name": "@lvce-editor/process-explorer",
  "version": "0.0.0-dev",
  "description": "Process Explorer",
  "main": "src/processExplorerMain.ts",
  "bin": "bin/processExplorer.js",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "lint": "eslint . && prettier --check .",
    "test": "node --unhandled-rejections=warn --experimental-vm-modules ./node_modules/jest/bin/jest.js --detectOpenHandles --forceExit",
    "test:watch": "node --unhandled-rejections=warn --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "type-check": "tsc"
  },
  "keywords": [
    "Lvce Editor"
  ],
  "author": "Lvce Editor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lvce-editor/process-explorer.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@lvce-editor/assert": "^1.5.1",
    "@lvce-editor/ipc": "^16.0.0",
    "@lvce-editor/json-rpc": "^8.0.0",
    "@lvce-editor/verror": "^1.7.0"
  },
  "optionalDependencies": {
    "@vscode/windows-process-tree": "^0.7.0"
  },
  "jest": {
    "injectGlobals": false,
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    }
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.29.7",
    "@lvce-editor/eslint-config": "^14.0.1",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "^20.12.8",
    "eslint": "^10.6.0",
    "execa": "^9.6.1",
    "jest": "^30.4.2",
    "prettier": "^3.9.3",
    "rollup": "^4.17.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  }
}
