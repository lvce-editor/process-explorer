    "@lvce-editor/eslint-config": "^14.0.1",
    "@types/node": "^20.12.8",
    "eslint": "^10.6.0",
    "knip": "^6.23.0",
    "lerna": "^8.2.3",
    "prettier": "^3.9.3",
    "ts-jest": "^29.4.11",
