{
  "name": "@lvce-editor/process-explorer-monorepo",
  "version": "0.0.0-dev",
  "private": true,
  "description": "Process Explorer",
  "type": "module",
  "scripts": {
    "build": "node packages/build/src/build.ts",
    "build:static": "node packages/build/src/build-static.ts",
    "build:watch": "./packages/build/node_modules/.bin/esbuild --format=esm --bundle --external:node:buffer --external:electron --external:node:worker_threads --watch packages/process-explorer-worker/src/processExplorerWorkerMain.ts --outfile=.tmp/dist-process-explorer-worker/index.js",
    "dev": "node packages/build/src/dev.ts",
    "e2e": "cd packages/e2e && npm run e2e",
    "e2e:firefox": "cd packages/e2e && npm run e2e:firefox",
    "e2e:firefox:headless": "cd packages/e2e && npm run e2e:firefox:headless",
    "e2e:headless": "cd packages/e2e && npm run e2e:headless",
    "e2e:webkit": "cd packages/e2e && npm run e2e:webkit",
    "e2e:webkit:headless": "cd packages/e2e && npm run e2e:webkit:headless",
    "postinstall": "lerna bootstrap --ci",
    "lint": "eslint . && prettier --check . && knip --no-config-hints",
    "test": "lerna run test",
    "test:watch": "cd packages/process-explorer && npm run test:watch",
    "type-check": "tsc -b"
  },
  "keywords": [
    "Lvce Editor"
  ],
  "author": "Lvce Editor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lvce-editor/process-explorer.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@lerna/legacy-package-management": "^8.2.4",
    "@lvce-editor/eslint-config": "^16.4.0",
    "@types/node": "^20.12.8",
    "eslint": "^10.7.0",
    "knip": "^6.24.0",
    "lerna": "^8.2.3",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  }
}
