{
  "name": "@lvce-editor/process-explorer",
  "version": "0.0.0-dev",
  "description": "Process Explorer",
  "main": "src/processExplorerMain.ts",
  "bin": "bin/processExplorer.js",
  "type": "module",
  "scripts": {
    "test": "node --unhandled-rejections=warn --experimental-vm-modules ./node_modules/jest/bin/jest.js --detectOpenHandles --forceExit",
    "test:watch": "node --unhandled-rejections=warn --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch"
  },
  "keywords": [
    "Lvce Editor"
  ],
  "author": "Lvce Editor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lvce-editor/process-explorer.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@lvce-editor/assert": "^1.5.1",
    "@lvce-editor/rpc": "^6.4.0",
    "@lvce-editor/rpc-registry": "^9.27.0",
    "@lvce-editor/verror": "^1.7.0"
  },
  "optionalDependencies": {
    "@vscode/windows-process-tree": "^0.7.0"
  },
  "jest": {
    "injectGlobals": false,
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    }
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/node": "^20.12.8",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11"
  }
}
