{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "project": ["*.js"],
      "ignoreDependencies": ["@lerna/legacy-package-management"]
    },
    "packages/build": {
      "entry": ["src/build.ts", "src/computeNodeModulesCacheKey.ts"],
      "ignoreDependencies": ["esbuild"],
      "project": ["src/**/*.ts"]
    },
    "packages/e2e": {
      "entry": ["src/**/*.ts", "scripts/*.js"],
      "project": ["src/**/*.ts", "scripts/*.js"]
    },
    "packages/process-explorer": {
      "entry": ["src/parts/**/*.ipc.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/process-explorer-worker": {
      "entry": ["src/processExplorerWorkerMain.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    }
  }
}
